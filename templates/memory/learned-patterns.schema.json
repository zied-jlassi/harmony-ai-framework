{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "harmony-learned-patterns",
  "title": "Harmony Learned Patterns",
  "description": "Schema for learned patterns and anti-patterns in Harmony Framework",
  "type": "object",
  "required": ["version", "patterns"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version"
    },
    "patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "category": { "type": "string" },
          "trigger": { "type": "string" },
          "action": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "applied_count": { "type": "integer", "minimum": 0 },
          "success_rate": { "type": "number", "minimum": 0, "maximum": 1 },
          "created_at": { "type": "string", "format": "date-time" },
          "last_applied": { "type": ["string", "null"], "format": "date-time" }
        },
        "required": ["id", "name", "trigger", "action"]
      }
    },
    "anti_patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "signature": { "type": "string" },
          "prevention": { "type": "string" },
          "occurrences": { "type": "integer", "minimum": 0 },
          "last_seen": { "type": ["string", "null"], "format": "date-time" }
        },
        "required": ["id", "name", "signature"]
      }
    },
    "statistics": {
      "type": "object",
      "properties": {
        "total_patterns": { "type": "integer", "minimum": 0 },
        "applied_count": { "type": "integer", "minimum": 0 },
        "prevented_errors": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
