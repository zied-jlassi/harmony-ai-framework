{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "harmony-sandbox-log",
  "title": "Harmony Sandbox Log",
  "description": "Schema for sandbox validation events",
  "type": "object",
  "required": ["version", "events"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version"
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "action": { "type": "string", "enum": ["validate", "sanitize", "block", "allow", "quarantine"] },
          "source": { "type": "string" },
          "input_type": { "type": "string" },
          "result": { "type": "string", "enum": ["passed", "sanitized", "blocked", "quarantined"] },
          "details": { "type": "string" }
        },
        "required": ["id", "timestamp", "action", "result"]
      }
    },
    "statistics": {
      "type": "object",
      "properties": {
        "total_validations": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "sanitized": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
