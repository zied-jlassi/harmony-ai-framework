# Continue Configuration for Harmony Framework
# Generated by /harmony install continue

name: {{PROJECT_NAME}}
version: 1.0.0
schema: v1

# ═══════════════════════════════════════════════════════════════
# MODELS
# ═══════════════════════════════════════════════════════════════

models:
  - name: Claude-Sonnet
    provider: anthropic
    model: claude-sonnet-4-20250514
    apiKey: ${ANTHROPIC_API_KEY}
    roles:
      - chat
      - edit
      - apply
    defaultCompletionOptions:
      temperature: 0.3
      maxTokens: 4096

  - name: Claude-Haiku
    provider: anthropic
    model: claude-haiku-4-20250514
    apiKey: ${ANTHROPIC_API_KEY}
    roles:
      - autocomplete
    defaultCompletionOptions:
      temperature: 0.1
      maxTokens: 1024

# ═══════════════════════════════════════════════════════════════
# RULES (Harmony Framework)
# ═══════════════════════════════════════════════════════════════

rules:
  # Guardian Protocol
  - "Before implementing code, check if a story exists for this work"
  - "Verify UCVs are approved before starting development"
  - "Route tasks to the appropriate Harmony agent"

  # Quality (HQVF)
  - "Never develop without approved UCVs"
  - "Mark verifications as you complete them"
  - "Write tests for new code"

  # Code Style
  - "Follow existing patterns in the codebase"
  - "Be concise - don't over-engineer"
  - "Reference files with line numbers"

  # Communication
  - "Be direct and actionable"
  - "Ask before making architectural changes"
  - "Explain trade-offs when relevant"

# ═══════════════════════════════════════════════════════════════
# CONTEXT PROVIDERS
# ═══════════════════════════════════════════════════════════════

contextProviders:
  - name: file
    params:
      path: ".harmony/agents/developer.md"

  - name: file
    params:
      path: "CLAUDE.md"

  - name: codebase
    params:
      nRetrieve: 10

# ═══════════════════════════════════════════════════════════════
# ASSISTANTS
# Reference assistants in .continue/assistants/
# ═══════════════════════════════════════════════════════════════

# Assistants are loaded from .continue/assistants/*.yaml
# Available:
# - harmony-developer (Developer)
# - harmony-tester (Tester)
# - harmony-analyst (Analyst)
# - harmony-guardian

# ═══════════════════════════════════════════════════════════════
# SLASH COMMANDS (Optional)
# ═══════════════════════════════════════════════════════════════

slashCommands:
  - name: story
    description: "Check for existing story"
    prompt: "Search for stories related to this task in docs/backlog/stories/"

  - name: ucv
    description: "Check UCV status"
    prompt: "Find the UCV file for the current story and show its status"
