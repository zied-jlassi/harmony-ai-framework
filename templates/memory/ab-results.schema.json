{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "harmony-ab-results",
  "title": "Harmony A/B Testing Results",
  "description": "Schema for A/B testing experiment results",
  "type": "object",
  "required": ["version", "experiments"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version"
    },
    "experiments": {
      "type": "object",
      "description": "Experiments indexed by name",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "variants": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "config": { "type": "object" },
                "trials": { "type": "integer" },
                "total_score": { "type": "number" },
                "scores": { "type": "array", "items": { "type": "number" } },
                "avg_score": { "type": "number" }
              }
            }
          },
          "results": { "type": "array" },
          "winner": { "type": ["string", "null"] },
          "status": { "type": "string", "enum": ["active", "concluded", "cancelled"] },
          "created_at": { "type": "string", "format": "date-time" },
          "completed_at": { "type": ["string", "null"], "format": "date-time" }
        },
        "required": ["id", "name", "variants", "status"]
      }
    },
    "statistics": {
      "type": "object",
      "properties": {
        "total_experiments": { "type": "integer", "minimum": 0 },
        "completed_experiments": { "type": "integer", "minimum": 0 },
        "total_results": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
