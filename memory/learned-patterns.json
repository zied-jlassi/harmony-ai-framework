      "title": "Bash set -e et expressions arithmetiques",
      "trigger": "Ecriture de script bash avec set -e",
      "rule": "JAMAIS utiliser ((var++)) ou ((var--)) avec set -e. Toujours utiliser var=$((var + 1)) ou var=$((var - 1))",
      "reason": "((0++)) retourne exit code 1 car 0 est falsy en bash. Avec set -e, le script meurt.",
      "bad_pattern": "((count++))",
      "good_pattern": "count=$((count + 1))",
      "cross_platform": {
        "sha256sum": "Utiliser shasum -a 256 sur macOS",
        "readlink_f": "Boucle manuelle car readlink -f n'existe pas sur macOS",
        "grep_no_match": "Ajouter || true car grep retourne 1 si aucun match"
      },
      "related_errors": ["ERR-002"],
      "related_doc": "P-011-bash-cross-platform.md",
      "tags": ["bash", "set-e", "arithmetic", "cross-platform"]
    }
