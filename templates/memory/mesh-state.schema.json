{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "harmony-mesh-state",
  "title": "Harmony Mesh Network State",
  "description": "Schema for agent mesh network state",
  "type": "object",
  "required": ["version", "meshes"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version"
    },
    "meshes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "agents": {
            "type": "array",
            "items": { "type": "string" }
          },
          "current_agent": { "type": ["string", "null"] },
          "status": { "type": "string", "enum": ["active", "idle", "completed", "failed"] },
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "from": { "type": "string" },
                "to": { "type": "string" },
                "content": { "type": "string" },
                "timestamp": { "type": "string", "format": "date-time" }
              }
            }
          },
          "handoffs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "from": { "type": "string" },
                "to": { "type": "string" },
                "context": { "type": "string" },
                "timestamp": { "type": "string", "format": "date-time" }
              }
            }
          },
          "created_at": { "type": "string", "format": "date-time" },
          "completed_at": { "type": ["string", "null"], "format": "date-time" }
        }
      }
    },
    "statistics": {
      "type": "object",
      "properties": {
        "total_meshes": { "type": "integer", "minimum": 0 },
        "active_meshes": { "type": "integer", "minimum": 0 },
        "total_handoffs": { "type": "integer", "minimum": 0 },
        "total_messages": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
